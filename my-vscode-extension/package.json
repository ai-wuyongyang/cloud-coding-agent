{
  "name": "ultimate-ai",
  "displayName": "ultimate ai",
  "description": "A simple VS Code sidebar chat extension for ultimate ai.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ultimateAiSidebar",
          "title": "ultimate ai",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "ultimateAiSidebar": [
        {
          "type": "webview",
          "id": "ultimateAiChatView",
          "name": "ultimate ai",
          "icon": "media/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "ultimateAi.openSidebar",
        "title": "Open Ultimate AI"
      }
    ]
  },
  "scripts": {
    "build:webview": "vite build --config vite.config.mjs",
    "dev:webview": "vite --config vite.config.mjs",
    "test": "echo \"No tests yet\""
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "vite": "^8.0.16",
    "vue": "^3.5.38"
  }
}
